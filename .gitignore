```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.exe
*.dll
*.so
*.class
*.out
*.a

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Build directories
dist/
build/
target/
.coverage
coverage/
htmlcov/

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo
*.tmp

# System files
.DS_Store
Thumbs.db
*.log

# Python specific
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/

# JavaScript/Node specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*
node_modules/
jspm_packages/

# Compression archives
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst

# Gradle
.gradle/
build/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# PyTest
.pytest_cache/

# VSCode
.vscode/
```